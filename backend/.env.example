# backend/.env.example
# v1.0.1 — Dashka German Translator
# Copy to .env for local development (NEVER commit .env)

# ── Required ─────────────────────────────────────────────────
OPENAI_API_KEY=REPLACE_ME

# ── Optional (defaults shown) ────────────────────────────────
NODE_ENV=development
PORT=8080
CORS_ORIGIN=*

